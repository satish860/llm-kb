{
  "name": "llm-kb",
  "version": "0.4.1",
  "description": "LLM-powered knowledge base. Drop documents, build a wiki, ask questions. Inspired by Karpathy.",
  "bin": {
    "llm-kb": "./bin/cli.js"
  },
  "files": [
    "bin/**",
    "README.md"
  ],
  "type": "module",
  "scripts": {
    "build": "tsup src/cli.ts --format esm --out-dir bin --clean",
    "dev": "tsup src/cli.ts --format esm --out-dir bin --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "llm",
    "knowledge-base",
    "wiki",
    "karpathy",
    "ai",
    "document",
    "pi-sdk"
  ],
  "author": "Satish Venkatakrishnan <satish@deltaxy.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/satish860/llm-kb"
  },
  "dependencies": {
    "@llamaindex/liteparse": "^1.4.4",
    "@mariozechner/pi-coding-agent": "^0.65.0",
    "adm-zip": "^0.5.17",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^13.1.0",
    "exceljs": "^4.4.0",

    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "officeparser": "^6.0.7"
  },
  "devDependencies": {
    "@types/marked-terminal": "^6.1.1",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  }
}
